# =================================================================
# 말자람터 공식 홈페이지 환경변수 템플릿 파일 (.env.example)
# =================================================================
# 이 파일을 복사하여 로컬에서는 .env.local 이름을 붙여 사용하세요.
# 실제 배포 시에는 Vercel 대시보드 [Settings] -> [Environment Variables]에 입력합니다.
# 주의: 실제 보안 API 키는 절대 깃허브 커밋에 포함하지 마세요!

# 1. Supabase 접속 정보 (공개 접근 가능 주소 및 키)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_anon_key"

# 2. 사이트 기본 도메인 주소 (SEO 및 OG 사이트맵 생성용)
NEXT_PUBLIC_SITE_URL="https://maljarumter.com"

# 3. 알림 서비스 프로바이더 선택 스위치 (mock | solapi | resend)
# 운영 준비 전까지는 'mock'으로 두시면 실제 과금 없이 시뮬레이션 작동합니다.
NOTIFICATION_PROVIDER="mock"

# 4. Solapi(구 CoolSMS) 실제 문자 발송 설정 (NOTIFICATION_PROVIDER="solapi" 일 때 활성화)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER_NUMBER="0212345678"

# 5. Resend 실제 이메일 발송 설정 (NOTIFICATION_PROVIDER="resend" 일 때 활성화)
RESEND_API_KEY=""
RESEND_SENDER_EMAIL="info@maljarumter.com"

# 6. 관리자 체험 모드 바이패스 (DB 계정 없이 관리자 UI 테스트 시 true)
BYPASS_ADMIN_AUTH="false"
